# DeepSeek AI 配置
DEEPSEEK_API_KEY=sk-你的API密钥

# 数据库配置（DB_* 或 MYSQL_* 均可）
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=你的数据库密码
DB_NAME=ai_content_platform

# 服务配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# JWT 认证
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRE_MINUTES=10080

# 微信公众号 API（可选，多用户模式下由平台绑定页配置）
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_ACCOUNT_ID=

# 微信发布偏好（可选）
WECHAT_DEFAULT_AUTHOR=娱乐八卦
WECHAT_NEED_OPEN_COMMENT=1
WECHAT_ONLY_FANS_CAN_COMMENT=0
WECHAT_DEFAULT_THEME=grace
